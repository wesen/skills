# Copy to ~/.config/ghidra-re/config.env or to the skill as local.env.
# macOS defaults:
# export GHIDRA_INSTALL_DIR='/Applications/Ghidra'
# export GHIDRA_JDK='/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home'
# Windows defaults (Git Bash style):
# export GHIDRA_INSTALL_DIR='/c/Program Files/Ghidra'
# export GHIDRA_JDK='/c/Program Files/Eclipse Adoptium/jdk-21'

export GHIDRA_INSTALL_DIR='/Applications/Ghidra'
export GHIDRA_JDK='/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home'
export GHIDRA_WORKSPACE="$HOME/ghidra-projects"
# export GHIDRA_RE_SOURCE_REGISTRY_FILE="$HOME/.config/ghidra-re/sources.json"

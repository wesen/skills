#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_create_data <address> <datatype> [key=value ...]
EOF
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

address="$1"
datatype="$2"
shift 2
body="$(ghidra_re_bridge_json_from_kv write=true destructive=true address="$address" datatype="$datatype" "$@")"
"$SCRIPT_DIR/ghidra_bridge_call" /data/create "$body"

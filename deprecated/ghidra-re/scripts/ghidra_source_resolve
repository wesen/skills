#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_source_resolve <name> </path/in/image> [copy=cache|direct]
EOF
}

[[ $# -ge 2 && $# -le 3 ]] || {
  usage >&2
  exit 1
}

source_name="$1"
source_path="$2"
copy_mode="cache"

if [[ $# -eq 3 ]]; then
  case "$3" in
    copy=*)
      copy_mode="${3#copy=}"
      ;;
    *)
      ghidra_re_die "unsupported argument: $3"
      ;;
  esac
fi

ghidra_re_source_resolve_path "$source_name" "$source_path" "$copy_mode"

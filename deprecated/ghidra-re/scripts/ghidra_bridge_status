#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

body='{}'
if [[ $# -gt 0 ]]; then
  body="$(ghidra_re_bridge_json_from_kv "$@")"
fi

ghidra_re_bridge_prune_stale_sessions

selector_values="$(ghidra_re_bridge_extract_selectors_from_json "$body")"
IFS=$'\t' read -r requested_session requested_project requested_program <<<"$selector_values"
if [[ -n "$requested_session" || -n "$requested_project" || -n "$requested_program" ]]; then
  if ! ghidra_re_bridge_select_session "$requested_session" "$requested_project" "$requested_program" >/dev/null 2>&1; then
    printf 'Bridge: disarmed\n'
    exit 0
  fi
fi

if ! ghidra_re_bridge_current_session_file >/dev/null 2>&1; then
  printf 'Bridge: disarmed\n'
  exit 0
fi

if ghidra_re_bridge_require_healthy_session >/dev/null 2>&1; then
  "$SCRIPT_DIR/ghidra_bridge_call" /session "$body"
  exit 0
fi

printf 'Bridge: stale or unreachable current session pointer at %s\n' "$GHIDRA_RE_BRIDGE_CURRENT_FILE"
cat "$GHIDRA_RE_BRIDGE_CURRENT_FILE"
exit 1

#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_mission_start <mission_name> goal=<goal> target=<binary|project:program|source:name:/path/in/image> [target=...] [seed=<kind:value>] [seed=...] [mode=trace]
EOF
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

mission_name="$1"
shift

goal=""
mode="trace"
targets=()
seeds=()

for arg in "$@"; do
  case "$arg" in
    goal=*)
      goal="${arg#goal=}"
      ;;
    mode=*)
      mode="${arg#mode=}"
      ;;
    target=*)
      targets+=("${arg#target=}")
      ;;
    seed=*)
      seeds+=("${arg#seed=}")
      ;;
    *)
      ghidra_re_die "unsupported argument: $arg"
      ;;
  esac
done

[[ -n "$goal" ]] || ghidra_re_die "goal=<goal> is required"
[[ ${#targets[@]} -gt 0 ]] || ghidra_re_die "at least one target=<binary|project:program> is required"

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_ensure_workspace
ghidra_re_bridge_ensure_dirs

mission_dir="$(ghidra_re_investigation_dir "$mission_name")"
mission_slug="$(ghidra_re_sanitize_name "$mission_name")"
backend="$(ghidra_re_mission_backend)"

targets_json="$(python3 - "${targets[@]}" <<'PY'
import json, sys
print(json.dumps(sys.argv[1:]))
PY
)"
if [[ ${#seeds[@]} -gt 0 ]]; then
  seeds_json="$(python3 - "${seeds[@]}" <<'PY'
import json, sys
print(json.dumps(sys.argv[1:]))
PY
)"
else
  seeds_json='[]'
fi

python3 "$backend" init \
  --mission-dir "$mission_dir" \
  --mission-name "$mission_name" \
  --goal "$goal" \
  --mode "$mode" \
  --targets-json "$targets_json" \
  --seeds-json "$seeds_json" >/dev/null

resolve_target_spec() {
  local spec="$1"
  local binary_path=""
  local project_name=""
  local program_name=""
  binary_path="$(ghidra_re_resolve_binary_spec "$spec" cache || true)"
  if [[ -n "$binary_path" && -f "$binary_path" ]]; then
    program_name="$(ghidra_re_program_name_from_binary "$binary_path")"
    project_name="${mission_slug}-$(ghidra_re_sanitize_name "$program_name")"
    if [[ ! -f "$(ghidra_re_project_file "$project_name")" ]]; then
      if [[ -z "${GHIDRA_IMPORT_DEMANGLE+x}" ]]; then
        GHIDRA_IMPORT_DEMANGLE=0 "$SCRIPT_DIR/ghidra_import_analyze" "$binary_path" "$project_name" >/dev/null
      else
        "$SCRIPT_DIR/ghidra_import_analyze" "$binary_path" "$project_name" >/dev/null
      fi
    fi
  elif [[ "$spec" == *:* ]]; then
    project_name="${spec%%:*}"
    program_name="${spec#*:}"
    [[ -n "$project_name" && -n "$program_name" ]] || ghidra_re_die "invalid target ref: $spec"
    ghidra_re_require_project "$project_name"
  else
    ghidra_re_die "target must be a binary path, source:name:/path reference, or project:program reference: $spec"
  fi
  printf '%s|%s|%s\n' "$binary_path" "$project_name" "$program_name"
}

ensure_export_bundle() {
  local project_name="$1"
  local program_name="$2"
  local export_dir=""
  local session_file=""
  local session_id=""
  export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"
  if [[ ! -f "$export_dir/program_summary.json" || ! -f "$export_dir/objc_metadata.json" || \
        ! -f "$export_dir/function_inventory.json" || ! -f "$export_dir/symbols.json" || \
        ! -f "$export_dir/strings.json" ]]; then
    session_file="$(ghidra_re_bridge_resolve_session_file "" "$project_name" "$program_name" || true)"
    if [[ -n "$session_file" ]]; then
      session_id="$(ghidra_re_bridge_read_value_from_file "$session_file" session_id || true)"
      if [[ -n "$session_id" ]]; then
        "$SCRIPT_DIR/ghidra_bridge_close" "session=${session_id}" >/dev/null 2>&1 || true
      fi
    fi
    if [[ -z "${GHIDRA_EXPORT_DEMANGLE+x}" ]]; then
      GHIDRA_EXPORT_DEMANGLE=0 "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
    else
      "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
    fi
  fi
}

write_target_manifest() {
  local manifest_path="$1"
  local target_key="$2"
  local binary_path="$3"
  local project_name="$4"
  local program_name="$5"
  local export_dir="$6"
  local session_file="${7:-}"
  local program_path="${8:-}"
  python3 - "$manifest_path" "$target_key" "$binary_path" "$project_name" "$program_name" "$export_dir" "$session_file" "$program_path" <<'PY'
import json, sys
from datetime import datetime, timezone
path, target_key, binary_path, project_name, program_name, export_dir, session_file, program_path = sys.argv[1:9]
payload = {
    "target_key": target_key,
    "binary_path": binary_path,
    "project_name": project_name,
    "program_name": program_name,
    "export_dir": export_dir,
    "session_file": session_file,
    "program_path": program_path,
    "recorded_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
PY
}

for target_spec in "${targets[@]}"; do
  IFS='|' read -r binary_path project_name program_name <<<"$(resolve_target_spec "$target_spec")"
  [[ -n "$project_name" && -n "$program_name" ]] || ghidra_re_die "failed to resolve target: $target_spec"
  ensure_export_bundle "$project_name" "$program_name"
  export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"
  target_key="$(ghidra_re_target_key "$project_name" "$program_name")"

  "$SCRIPT_DIR/ghidra_bridge_open" "$project_name" "$program_name" >/dev/null
  session_file="$(ghidra_re_bridge_resolve_session_file "" "$project_name" "$program_name" || true)"
  [[ -n "$session_file" ]] || ghidra_re_die "failed to locate live session for $target_key"
  program_path="$(ghidra_re_bridge_read_value_from_file "$session_file" program_path || true)"

  python3 "$backend" register-target \
    --mission-dir "$mission_dir" \
    --target-key "$target_key" \
    --project-name "$project_name" \
    --program-name "$program_name" \
    --binary-path "$binary_path" \
    --program-path "$program_path" \
    --export-dir "$export_dir" >/dev/null

  python3 "$backend" register-session \
    --mission-dir "$mission_dir" \
    --session-file "$session_file" >/dev/null

  python3 "$backend" ingest-export \
    --mission-dir "$mission_dir" \
    --target-key "$target_key" \
    --export-dir "$export_dir" >/dev/null

  target_dir="$mission_dir/exports/targets/${project_name}__${program_name}"
  mkdir -p "$target_dir"
  write_target_manifest "$target_dir/target.json" "$target_key" "$binary_path" "$project_name" "$program_name" "$export_dir" "$session_file" "$program_path"
done

if [[ ${#seeds[@]} -gt 0 ]]; then
  for seed in "${seeds[@]}"; do
    "$SCRIPT_DIR/ghidra_mission_trace" "$mission_name" "seed=$seed" >/dev/null
  done
fi

python3 "$backend" render-report --mission-dir "$mission_dir" >/dev/null

printf 'Mission started: %s\n' "$mission_name"
printf 'Mission dir: %s\n' "$mission_dir"
printf 'Report: %s\n' "$mission_dir/reports/latest.md"

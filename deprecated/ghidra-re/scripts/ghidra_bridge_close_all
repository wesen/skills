#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_close_all [mission=<mission_name>] [all=true]
EOF
}

mission_name=""
all_flag=true
status_file=""

for arg in "$@"; do
  case "$arg" in
    mission=*)
      mission_name="${arg#mission=}"
      all_flag=false
      ;;
    all=*)
      case "${arg#all=}" in
        true|1|yes|on) all_flag=true ;;
        false|0|no|off) all_flag=false ;;
        *) ghidra_re_die "unsupported all= value: ${arg#all=}" ;;
      esac
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ghidra_re_die "unsupported argument: $arg"
      ;;
  esac
done

ghidra_re_bridge_prune_stale_sessions

sessions_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-re-sessions.XXXXXX")"
selection_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-re-close-selection.XXXXXX")"
patterns_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-re-close-patterns.XXXXXX")"

cleanup() {
  rm -f "$sessions_file" "$selection_file" "$patterns_file"
}
trap cleanup EXIT

"$SCRIPT_DIR/ghidra_bridge_sessions" >"$sessions_file"

if [[ "$all_flag" == true ]]; then
  python3 - "$sessions_file" >"$selection_file" <<'PY'
import json, pathlib, sys
sessions = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
for item in sessions:
    session_id = item.get("session_id", "")
    if session_id:
        print(session_id)
PY
elif [[ -n "$mission_name" ]]; then
  mission_dir="$(ghidra_re_investigation_dir "$mission_name")"
  [[ -d "$mission_dir" ]] || ghidra_re_die "mission not found: $mission_name"
  status_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-re-mission-status.XXXXXX")"
  trap 'rm -f "$sessions_file" "$selection_file" "$patterns_file" "$status_file"' EXIT
  python3 "$(ghidra_re_mission_backend)" status --mission-dir "$mission_dir" >"$status_file"
  python3 - "$sessions_file" "$status_file" >"$selection_file" <<'PY'
import json, pathlib, sys
sessions = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
status = json.loads(pathlib.Path(sys.argv[2]).read_text(encoding="utf-8"))
targets = {
    (item.get("project_name", ""), item.get("program_name", ""))
    for item in status.get("targets_visited", [])
}
for item in sessions:
    key = (item.get("project_name", ""), item.get("program_name", ""))
    if key in targets and item.get("session_id"):
        print(item["session_id"])
PY
else
  ghidra_re_die "pass mission=<name> or all=true"
fi

python3 - "$sessions_file" "$selection_file" "$status_file" "$all_flag" <<'PY' >"$patterns_file"
import json
import pathlib
import sys

sessions = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
selected_ids = {
    line.strip()
    for line in pathlib.Path(sys.argv[2]).read_text(encoding="utf-8").splitlines()
    if line.strip()
}
status_file = sys.argv[3]
all_flag = sys.argv[4].lower() == "true"

if all_flag:
    print("ALL_WORKSPACE_PROJECTS")

for item in sessions:
    if item.get("session_id") in selected_ids:
        for key in ("project_path", "project_name"):
            value = item.get(key, "")
            if value:
                print(value)

if status_file and pathlib.Path(status_file).exists():
    status = json.loads(pathlib.Path(status_file).read_text(encoding="utf-8"))
    for item in status.get("targets_visited", []):
        project_name = item.get("project_name", "")
        if project_name:
            print(project_name)
PY

closed_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-re-close-closed.XXXXXX")"
failed_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-re-close-failed.XXXXXX")"
lingering_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-re-close-lingering.XXXXXX")"
trap 'rm -f "$sessions_file" "$selection_file" "$patterns_file" "$closed_file" "$failed_file" "$lingering_file" "${status_file:-}"' EXIT

while IFS= read -r session_id; do
  [[ -n "$session_id" ]] || continue
  if "$SCRIPT_DIR/ghidra_bridge_close" "session=$session_id" >/dev/null 2>&1; then
    printf '%s\n' "$session_id" >>"$closed_file"
  else
    printf '%s\n' "$session_id" >>"$failed_file"
  fi
done <"$selection_file"

python3 - "$patterns_file" "$GHIDRA_PROJECTS_DIR" >"$lingering_file" <<'PY'
import pathlib
import subprocess
import sys

patterns = {
    line.strip()
    for line in pathlib.Path(sys.argv[1]).read_text(encoding="utf-8").splitlines()
    if line.strip()
}
workspace = sys.argv[2]
all_workspace = "ALL_WORKSPACE_PROJECTS" in patterns
patterns.discard("ALL_WORKSPACE_PROJECTS")

result = subprocess.run(
    ["ps", "ax", "-o", "pid=", "-o", "command="],
    check=True,
    capture_output=True,
    text=True,
)

for raw_line in result.stdout.splitlines():
    line = raw_line.strip()
    if not line:
      continue
    try:
      pid, command = line.split(None, 1)
    except ValueError:
      continue
    interesting = (
        "ghidra.GhidraRun" in command
        or "ghidraRun" in command
        or "codex-ghidra-" in command
    )
    if not interesting:
        continue
    if all_workspace:
        if workspace and workspace in command:
            print(pid)
        continue
    if any(pattern in command for pattern in patterns):
        print(pid)
PY

if [[ -s "$lingering_file" ]]; then
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    kill "$pid" >/dev/null 2>&1 || true
  done <"$lingering_file"
  sleep 2
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill -9 "$pid" >/dev/null 2>&1 || true
    fi
  done <"$lingering_file"
fi

python3 - "$closed_file" "$failed_file" "$lingering_file" "$mission_name" "$all_flag" <<'PY'
import json, pathlib, sys

def read_lines(path_str):
    path = pathlib.Path(path_str)
    if not path.exists():
        return []
    return [line.strip() for line in path.read_text(encoding="utf-8").splitlines() if line.strip()]

closed = read_lines(sys.argv[1])
failed = read_lines(sys.argv[2])
lingering = read_lines(sys.argv[3])
payload = {
    "ok": len(failed) == 0,
    "mission_name": sys.argv[4],
    "all": sys.argv[5].lower() == "true",
    "closed_sessions": closed,
    "failed_sessions": failed,
    "terminated_processes": lingering,
    "closed_count": len(closed),
    "failed_count": len(failed),
    "terminated_process_count": len(lingering),
}
print(json.dumps(payload, indent=2))
PY

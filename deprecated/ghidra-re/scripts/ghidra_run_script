#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_run_script <project_name> <program_name> <script_name> [script args...]
Notes:
  - Prefer script args in key=value form.
  - --key value and --key=value are rewritten to key=value.
EOF
}

[[ $# -ge 3 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
raw_script_name="$3"
shift 3

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_ensure_workspace
ghidra_re_require_project "$project_name"

script_name="$raw_script_name"
extra_script_dir=""
if [[ "$raw_script_name" == */* ]]; then
  [[ -f "$raw_script_name" ]] || ghidra_re_die "script path not found: $raw_script_name"
  extra_script_dir="$(cd "$(dirname "$raw_script_name")" && pwd)"
  script_name="$(basename "$raw_script_name")"
fi

normalized_args=()
while IFS= read -r -d '' item; do
  normalized_args+=("$item")
done < <(ghidra_re_normalize_script_args "$@")

script_path="$(ghidra_re_script_path "$extra_script_dir")"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
safe_script_name="$(ghidra_re_sanitize_name "$script_name")"
log_file="$log_dir/script-${safe_script_name}-${timestamp}.log"
script_log="$log_dir/script-${safe_script_name}-${timestamp}.script.log"
analyze_headless="$(ghidra_re_analyze_headless_path)"

optional_args=()
while IFS= read -r -d '' item; do
  optional_args+=("$item")
done < <(ghidra_re_optional_headless_args)

analysis_args=()
case "${GHIDRA_RUN_SCRIPT_ANALYZE:-0}" in
  1|true|yes|on)
    ;;
  0|false|no|off|"")
    analysis_args=(-noanalysis)
    ;;
  *)
    ghidra_re_die "unsupported GHIDRA_RUN_SCRIPT_ANALYZE: ${GHIDRA_RUN_SCRIPT_ANALYZE}"
    ;;
esac

read_only_args=()
case "${GHIDRA_RUN_SCRIPT_MODE:-readwrite}" in
  readwrite|rw|"")
    ;;
  readonly|read-only|ro)
    read_only_args=(-readOnly)
    ;;
  *)
    ghidra_re_die "unsupported GHIDRA_RUN_SCRIPT_MODE: ${GHIDRA_RUN_SCRIPT_MODE}"
    ;;
esac

cmd=(
  "$analyze_headless"
  "$(ghidra_re_project_location "$project_name")"
  "$project_name"
  -process "$program_name"
  -scriptPath "$script_path"
)
if [[ ${#analysis_args[@]} -gt 0 ]]; then
  cmd+=("${analysis_args[@]}")
fi
if [[ ${#read_only_args[@]} -gt 0 ]]; then
  cmd+=("${read_only_args[@]}")
fi
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
cmd+=(
  -postScript "$script_name"
)
if [[ ${#normalized_args[@]} -gt 0 ]]; then
  cmd+=("${normalized_args[@]}")
fi
cmd+=(
  -log "$log_file"
  -scriptlog "$script_log"
)

"${cmd[@]}"

expected_outputs=()
if [[ ${#normalized_args[@]} -gt 0 ]]; then
  for arg in "${normalized_args[@]}"; do
    if [[ "$arg" == output=* ]]; then
      expected_outputs+=("${arg#output=}")
    fi
  done
fi
if [[ ${#expected_outputs[@]} -gt 0 ]]; then
  for output_path in "${expected_outputs[@]}"; do
    [[ -f "$output_path" ]] || ghidra_re_die "script reported success but output file is missing: $output_path"
  done
fi

printf 'Ran script %s on %s/%s\n' "$script_name" "$project_name" "$program_name"
printf 'Log: %s\n' "$log_file"
printf 'Script log: %s\n' "$script_log"

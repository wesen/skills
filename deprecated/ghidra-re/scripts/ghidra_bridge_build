#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

ghidra_re_require_tools
ghidra_re_export_env

[[ -d "$GHIDRA_RE_BRIDGE_EXTENSION_DIR" ]] || \
  ghidra_re_die "bridge extension directory not found at $GHIDRA_RE_BRIDGE_EXTENSION_DIR"

gradle_wrapper="$(ghidra_re_gradle_wrapper_path)"

"$gradle_wrapper" \
  -p "$GHIDRA_RE_BRIDGE_EXTENSION_DIR" \
  -PGHIDRA_INSTALL_DIR="$GHIDRA_INSTALL_DIR" \
  clean \
  distributeExtension

printf 'Built bridge extension: %s\n' "$(ghidra_re_bridge_dist_zip)"

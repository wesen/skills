#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_arm <project_name> [program_name]
EOF
}

[[ $# -ge 1 && $# -le 2 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="${2:-}"
project_file="$(ghidra_re_project_file "$project_name")"

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_require_project "$project_name"
ghidra_re_bridge_prune_stale_sessions

if [[ ! -d "$(ghidra_re_bridge_installed_dir)" ]]; then
  "$SCRIPT_DIR/ghidra_bridge_install"
fi

existing_session_file="$(ghidra_re_bridge_resolve_session_file "" "$project_name" "$program_name" 2>/dev/null || true)"
if [[ -n "$existing_session_file" ]] && ghidra_re_bridge_session_healthy_file "$existing_session_file"; then
  ghidra_re_bridge_write_current_from_session_file "$existing_session_file"
  printf 'Bridge already armed at %s\n' "$(ghidra_re_bridge_read_value_from_file "$existing_session_file" bridge_url)"
  printf 'Session: %s\n' "$existing_session_file"
  exit 0
fi

ghidra_re_bridge_write_request_file arm "" "$project_name" "$program_name" >/dev/null

if ghidra_re_ghidra_running; then
  printf 'Waiting for a running Ghidra session to consume the arm request\n'
  session_file="$(ghidra_re_bridge_wait_for_session 8 "$project_name" "$program_name" || true)"
  if [[ -n "$session_file" ]]; then
    ghidra_re_bridge_write_current_from_session_file "$session_file"
    printf 'Bridge armed at %s\n' "$(ghidra_re_bridge_read_value_from_file "$session_file" bridge_url)"
    printf 'Session: %s\n' "$session_file"
    exit 0
  fi
fi

if ghidra_re_ghidra_running; then
  printf 'Launching a detached Ghidra instance for %s\n' "$project_name"
  ghidra_re_launch_gui_project "$project_file" new-instance
else
  printf 'Launching Ghidra for %s\n' "$project_name"
  ghidra_re_launch_gui_project "$project_file"
fi

session_file="$(ghidra_re_bridge_wait_for_session 60 "$project_name" "$program_name" || true)"
if [[ -z "$session_file" ]]; then
  ghidra_re_die "timed out waiting for bridge session; open the project in Ghidra and run EnableCodexBridge.java once if needed"
fi

ghidra_re_bridge_write_current_from_session_file "$session_file"
printf 'Bridge armed at %s\n' "$(ghidra_re_bridge_read_value_from_file "$session_file" bridge_url)"
printf 'Session: %s\n' "$session_file"

#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_delete_data <address> [end] [key=value ...]
EOF
}

[[ $# -ge 1 ]] || {
  usage >&2
  exit 1
}

address="$1"
shift
end="$address"
if [[ $# -gt 0 && "$1" != *=* ]]; then
  end="$1"
  shift
fi
body="$(ghidra_re_bridge_json_from_kv write=true destructive=true address="$address" end="$end" "$@")"
"$SCRIPT_DIR/ghidra_bridge_call" /data/delete "$body"

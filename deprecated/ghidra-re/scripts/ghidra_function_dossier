#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_function_dossier <project_name> <program_name> <function_or_address>
EOF
}

[[ $# -eq 3 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
target="$3"

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_ensure_workspace
ghidra_re_require_project "$project_name"

manifest_path="$(ghidra_re_bug_hunt_manifest)"
slug="$(basename "$(printf '%s' "$target" | tr '[:space:]/:' '_' )")"
slug="$(ghidra_re_sanitize_name "$slug")"
dossier_dir="$(ghidra_re_dossiers_dir "$project_name" "$program_name")/$slug"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
log_file="$log_dir/dossier-${slug}-${timestamp}.log"
script_log="$log_dir/dossier-${slug}-${timestamp}.script.log"
script_path="$(ghidra_re_script_path)"
analyze_headless="$(ghidra_re_analyze_headless_path)"

mkdir -p "$dossier_dir" "$log_dir"

target_arg_name="function"
if [[ "$target" =~ ^0x[0-9a-fA-F]+$ || "$target" =~ ^[0-9a-fA-F]+$ ]]; then
  target_arg_name="address"
fi

optional_args=()
while IFS= read -r -d '' item; do
  optional_args+=("$item")
done < <(ghidra_re_optional_headless_args)

analysis_args=()
case "${GHIDRA_DOSSIER_ANALYZE:-0}" in
  1|true|yes|on)
    ;;
  0|false|no|off|"")
    analysis_args=(-noanalysis)
    ;;
  *)
    ghidra_re_die "unsupported GHIDRA_DOSSIER_ANALYZE: ${GHIDRA_DOSSIER_ANALYZE}"
    ;;
esac

cmd=(
  "$analyze_headless"
  "$(ghidra_re_project_location "$project_name")"
  "$project_name"
  -process "$program_name"
  -readOnly
  -scriptPath "$script_path"
)
if [[ ${#analysis_args[@]} -gt 0 ]]; then
  cmd+=("${analysis_args[@]}")
fi
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
cmd+=(
  -postScript ExportFunctionDossier.java \
    "manifest=${manifest_path}" \
    "output_dir=${dossier_dir}" \
    "${target_arg_name}=${target}" \
    "sample_limit=${GHIDRA_DOSSIER_SAMPLE_LIMIT:-25}" \
    "timeout=${GHIDRA_DOSSIER_TIMEOUT:-60}" \
  -log "$log_file"
  -scriptlog "$script_log"
)

"${cmd[@]}"

expected_files=(
  "$dossier_dir/context.json"
  "$dossier_dir/decompile.c"
  "$dossier_dir/summary.md"
)
for output_path in "${expected_files[@]}"; do
  [[ -f "$output_path" ]] || ghidra_re_die "expected dossier file is missing: $output_path"
done

printf 'Exported function dossier for %s/%s target %s\n' "$project_name" "$program_name" "$target"
printf 'Dossier dir: %s\n' "$dossier_dir"
printf 'Files:\n'
printf '  %s\n' "$dossier_dir/context.json"
printf '  %s\n' "$dossier_dir/decompile.c"
printf '  %s\n' "$dossier_dir/summary.md"
printf 'Log: %s\n' "$log_file"
printf 'Script log: %s\n' "$script_log"

#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: bootstrap [--skip-smoke-test] [--skip-bridge-install] [--config-file PATH] [--no-write-config]

Bootstraps ghidra-re on a new machine by:
  - detecting Ghidra and Java
  - creating the default workspace directories
  - writing a config file for future runs
  - optionally running a tiny analyzeHeadless smoke test
  - installing the live bridge extension into the user's Ghidra settings
EOF
}

run_smoke_test=1
run_bridge_install=1
write_config=1
config_file="$GHIDRA_RE_USER_CONFIG"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skip-smoke-test)
      run_smoke_test=0
      shift
      ;;
    --skip-bridge-install)
      run_bridge_install=0
      shift
      ;;
    --no-write-config)
      write_config=0
      shift
      ;;
    --config-file)
      [[ $# -ge 2 ]] || ghidra_re_die "missing value for --config-file"
      config_file="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ghidra_re_die "unknown argument: $1"
      ;;
  esac
done

write_config_file() {
  local target="$1"
  local ghidra_dir="$2"
  local jdk_dir="$3"
  local workspace="$4"
  mkdir -p "$(dirname "$target")"
  cat >"$target" <<EOF
# Generated by ghidra-re bootstrap on $(date '+%Y-%m-%d %H:%M:%S %Z')
export GHIDRA_INSTALL_DIR='$ghidra_dir'
export GHIDRA_JDK='$jdk_dir'
export GHIDRA_WORKSPACE='$workspace'
EOF
}

run_bootstrap_smoke_test() {
  local ghidra_dir="$1"
  local jdk_dir="$2"
  local smoke_binary="/usr/bin/true"
  local tmp_root=""
  local project_root=""
  local project_name="bootstrap-smoke"
  local analyze_headless=""

  [[ -x "$smoke_binary" ]] || smoke_binary="/bin/ls"
  if ghidra_re_platform_is_windows; then
    [[ -x "$smoke_binary" ]] || smoke_binary="/c/Windows/System32/where.exe"
  fi
  [[ -x "$smoke_binary" ]] || ghidra_re_die "unable to find a small system binary for smoke testing"
  analyze_headless="$(ghidra_re_analyze_headless_path "$ghidra_dir")"

  tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/ghidra-re-bootstrap.XXXXXX")"
  project_root="$tmp_root/project"
  mkdir -p "$project_root"
  JAVA_HOME="$jdk_dir" PATH="$jdk_dir/bin:$PATH" \
    "$analyze_headless" \
    "$project_root" \
    "$project_name" \
    -import "$smoke_binary" \
    -overwrite \
    -noanalysis \
    -max-cpu 1 \
    -scriptPath "$GHIDRA_CUSTOM_SCRIPTS_DIR" \
    -log "$tmp_root/bootstrap.log" \
    -scriptlog "$tmp_root/bootstrap.script.log" \
    >/dev/null 2>&1 || {
      rm -rf "$tmp_root"
      return 1
    }

  [[ -f "$project_root/$project_name.gpr" ]] || {
    rm -rf "$tmp_root"
    return 1
  }
  rm -rf "$tmp_root"
}

detected_ghidra_dir="$(ghidra_re_detect_ghidra_dir || true)"
detected_jdk_dir="$(ghidra_re_detect_jdk_dir || true)"
workspace_root="${GHIDRA_WORKSPACE:-$HOME/ghidra-projects}"

[[ -n "$detected_ghidra_dir" ]] || ghidra_re_die "could not detect a Ghidra install; run scripts/doctor for details"
[[ -n "$detected_jdk_dir" ]] || ghidra_re_die "could not detect a Java 21 JDK; run scripts/doctor for details"

mkdir -p \
  "$workspace_root/projects" \
  "$workspace_root/exports" \
  "$workspace_root/logs" \
  "$workspace_root/investigations" \
  "$workspace_root/sources"

if [[ "$write_config" -eq 1 ]]; then
  write_config_file "$config_file" "$detected_ghidra_dir" "$detected_jdk_dir" "$workspace_root"
fi

if [[ "$run_smoke_test" -eq 1 ]]; then
  run_bootstrap_smoke_test "$detected_ghidra_dir" "$detected_jdk_dir" || \
    ghidra_re_die "analyzeHeadless smoke test failed; run scripts/doctor for details"
fi

bridge_status="skipped"
if [[ "$run_bridge_install" -eq 1 ]]; then
  if "$SCRIPT_DIR/ghidra_bridge_install" >/dev/null 2>&1; then
    bridge_status="installed"
  else
    ghidra_re_die "bridge install failed; run scripts/doctor for details"
  fi
fi

printf 'ghidra-re bootstrap complete\n'
printf 'Skill root: %s\n' "$GHIDRA_RE_ROOT"
printf 'Ghidra: %s\n' "$detected_ghidra_dir"
printf 'JDK: %s\n' "$detected_jdk_dir"
printf 'Workspace: %s\n' "$workspace_root"
if [[ "$write_config" -eq 1 ]]; then
  printf 'Config: %s\n' "$config_file"
else
  printf 'Config: not written (--no-write-config)\n'
fi
if [[ "$run_smoke_test" -eq 1 ]]; then
  printf 'Smoke test: passed\n'
else
  printf 'Smoke test: skipped\n'
fi
printf 'Bridge: %s\n' "$bridge_status"

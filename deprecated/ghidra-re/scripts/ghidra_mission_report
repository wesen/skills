#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_mission_report <mission_name> [format=markdown|json|path]
EOF
}

[[ $# -ge 1 && $# -le 2 ]] || {
  usage >&2
  exit 1
}

mission_name="$1"
format="markdown"
if [[ $# -eq 2 ]]; then
  case "$2" in
    format=*)
      format="${2#format=}"
      ;;
    *)
      ghidra_re_die "unsupported argument: $2"
      ;;
  esac
fi

mission_dir="$(ghidra_re_investigation_dir "$mission_name")"
[[ -d "$mission_dir" ]] || ghidra_re_die "mission not found: $mission_name"

case "$format" in
  json)
    python3 "$(ghidra_re_mission_backend)" render-report --mission-dir "$mission_dir"
    ;;
  markdown)
    python3 "$(ghidra_re_mission_backend)" render-report --mission-dir "$mission_dir" >/dev/null
    cat "$mission_dir/reports/latest.md"
    ;;
  path)
    python3 "$(ghidra_re_mission_backend)" render-report --mission-dir "$mission_dir" >/dev/null
    printf '%s\n' "$mission_dir/reports/latest.md"
    ;;
  *)
    ghidra_re_die "unsupported format: $format"
    ;;
esac

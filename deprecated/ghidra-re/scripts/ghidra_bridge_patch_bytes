#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_patch_bytes <address> <hex_bytes> [key=value ...]
EOF
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

address="$1"
hex_bytes="$2"
shift 2
body="$(ghidra_re_bridge_json_from_kv write=true destructive=true address="$address" bytes="$hex_bytes" "$@")"
"$SCRIPT_DIR/ghidra_bridge_call" /patch/bytes "$body"

#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

requested_session=""
requested_project=""
requested_program=""

for arg in "$@"; do
  case "$arg" in
    session=*)
      requested_session="${arg#session=}"
      ;;
    project=*)
      requested_project="${arg#project=}"
      ;;
    program=*)
      requested_program="${arg#program=}"
      ;;
    *)
      ghidra_re_die "unsupported argument: $arg"
      ;;
  esac
done

session_file="$(ghidra_re_bridge_resolve_session_file "$requested_session" "$requested_project" "$requested_program")"
session_id="$(ghidra_re_bridge_read_value_from_file "$session_file" session_id)"
pid="$(ghidra_re_bridge_read_value_from_file "$session_file" pid)"

"$SCRIPT_DIR/ghidra_bridge_disarm" "session=${session_id}"

if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
  command_line="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  if printf '%s' "$command_line" | grep -Eq 'ghidra\.GhidraRun|ghidraRun(\.bat)?|launch\.(sh|bat)'; then
    kill "$pid" >/dev/null 2>&1 || true
  fi
fi

printf 'Closed session: %s\n' "$session_id"

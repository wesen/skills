#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

settings_dir="$(ghidra_re_bridge_settings_dir)"
extensions_dir="$(ghidra_re_bridge_extensions_dir)"
installed_dir="$(ghidra_re_bridge_installed_dir)"
tools_dir="$(ghidra_re_bridge_tools_dir)"
frontend_tool_file="$settings_dir/FrontEndTool.xml"
legacy_installed_dir="$settings_dir/Extensions/Ghidra/CodexGhidraBridge"
zip_path=""

ghidra_re_require_tools
ghidra_re_export_env

if [[ ! -d "$GHIDRA_RE_BRIDGE_DIST_DIR" ]] || \
   ! find "$GHIDRA_RE_BRIDGE_DIST_DIR" -maxdepth 1 -type f -name 'ghidra_*_CodexGhidraBridge.zip' | grep -q .
then
  "$SCRIPT_DIR/ghidra_bridge_build"
fi

zip_path="$(ghidra_re_bridge_dist_zip)"

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/ghidra-bridge-install.XXXXXX")"
cleanup() {
  rm -rf "$tmp_root"
}
trap cleanup EXIT

mkdir -p "$extensions_dir"
"$(ghidra_re_python)" - "$zip_path" "$tmp_root" <<'PY'
import pathlib
import sys
import zipfile

zip_path = pathlib.Path(sys.argv[1])
target_dir = pathlib.Path(sys.argv[2])
with zipfile.ZipFile(zip_path) as archive:
    archive.extractall(target_dir)
PY
rm -rf "$installed_dir"
cp -R "$tmp_root/CodexGhidraBridge" "$installed_dir"
rm -rf "$legacy_installed_dir"

if [[ -d "$tools_dir" ]]; then
  while IFS= read -r tool_file; do
    "$(ghidra_re_python)" - "$tool_file" <<'PY'
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
xml = path.read_text(encoding="utf-8")
original = xml
xml = re.sub(r'\n\s*<PACKAGE NAME="Codex Bridge">\s*<INCLUDE CLASS="codexghidrabridge\.[^"]+" />\s*</PACKAGE>', '', xml, flags=re.S)
xml = re.sub(r'\n\s*<INCLUDE CLASS="codexghidrabridge\.CodexBridgePlugin" />', '', xml)
if path.name == "_code_browser.tcd" and "codexghidrabridge.CodexBridgePlugin" not in xml:
    replacement = '\n            <INCLUDE CLASS="codexghidrabridge.CodexBridgePlugin" />'
    xml, count = re.subn(r'(<PACKAGE NAME="Ghidra Core">.*?)(\n\s*</PACKAGE>)', r'\1' + replacement + r'\2', xml, count=1, flags=re.S)
    if count == 0:
        xml = re.sub(
            r'<PACKAGE NAME="Ghidra Core"\s*/>',
            '<PACKAGE NAME="Ghidra Core">\n            <INCLUDE CLASS="codexghidrabridge.CodexBridgePlugin" />\n        </PACKAGE>',
            xml,
            count=1,
        )
if xml != original:
    path.write_text(xml, encoding="utf-8")
PY
  done < <(find "$tools_dir" -maxdepth 1 -type f -name '*.tcd' | sort)
fi

if [[ -f "$frontend_tool_file" ]]; then
  "$(ghidra_re_python)" - "$frontend_tool_file" <<'PY'
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
xml = path.read_text(encoding="utf-8")
original = xml
xml = re.sub(r'\n\s*<PACKAGE NAME="Codex Bridge">\s*<INCLUDE CLASS="codexghidrabridge\.[^"]+" />\s*</PACKAGE>', '', xml, flags=re.S)
if "codexghidrabridge.CodexBridgeFrontEndPlugin" not in xml:
    xml, count = re.subn(
        r'<PACKAGE NAME="Ghidra Core"\s*/>',
        '<PACKAGE NAME="Ghidra Core">\n                <INCLUDE CLASS="codexghidrabridge.CodexBridgeFrontEndPlugin" />\n            </PACKAGE>',
        xml,
        count=1,
    )
    if count == 0:
        xml = re.sub(
            r'(<PACKAGE NAME="Ghidra Core">.*?)(\n\s*</PACKAGE>)',
            r'\1\n                <INCLUDE CLASS="codexghidrabridge.CodexBridgeFrontEndPlugin" />\2',
            xml,
            count=1,
            flags=re.S,
        )
if xml != original:
    path.write_text(xml, encoding="utf-8")
PY
fi

printf 'Installed bridge extension to %s\n' "$installed_dir"
printf 'Ghidra settings: %s\n' "$settings_dir"
printf 'Restart Ghidra if it was already running.\n'

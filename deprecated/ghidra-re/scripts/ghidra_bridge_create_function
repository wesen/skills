#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_create_function <entry> [name] [end] [key=value ...]
EOF
}

[[ $# -ge 1 ]] || {
  usage >&2
  exit 1
}

entry="$1"
shift
name=""
end=""
if [[ $# -gt 0 && "$1" != *=* ]]; then
  name="$1"
  shift
fi
if [[ $# -gt 0 && "$1" != *=* ]]; then
  end="$1"
  shift
fi

args=(write=true destructive=true entry="$entry")
[[ -n "$name" ]] && args+=(name="$name")
[[ -n "$end" ]] && args+=(end="$end")
args+=("$@")
body="$(ghidra_re_bridge_json_from_kv "${args[@]}")"
"$SCRIPT_DIR/ghidra_bridge_call" /function/create "$body"

#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_source_add <name> root=<path> [platform=macos-image] [copy=cache|direct] [description=...]
EOF
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

source_name="$1"
shift

root=""
platform="macos-image"
copy_mode="cache"
description=""

for arg in "$@"; do
  case "$arg" in
    root=*)
      root="${arg#root=}"
      ;;
    platform=*)
      platform="${arg#platform=}"
      ;;
    copy=*)
      copy_mode="${arg#copy=}"
      ;;
    description=*)
      description="${arg#description=}"
      ;;
    *)
      ghidra_re_die "unsupported argument: $arg"
      ;;
  esac
done

[[ -n "$source_name" && -n "$root" ]] || ghidra_re_die "name and root=... are required"
[[ -d "$root" ]] || ghidra_re_die "source root not found: $root"

ghidra_re_source_registry_init
"$(ghidra_re_python)" - "$GHIDRA_RE_SOURCE_REGISTRY_FILE" "$source_name" "$root" "$platform" "$copy_mode" "$description" <<'PY'
import json, pathlib, sys
path = pathlib.Path(sys.argv[1])
name, root, platform, copy_mode, description = sys.argv[2:7]
payload = json.loads(path.read_text(encoding="utf-8"))
sources = [item for item in payload.get("sources", []) if item.get("name") != name]
sources.append({
    "name": name,
    "root": root,
    "platform": platform,
    "copy": copy_mode,
    "description": description,
})
sources.sort(key=lambda item: item.get("name", ""))
payload["sources"] = sources
path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
PY

printf 'Registered source: %s\n' "$source_name"
printf 'Root: %s\n' "$root"
printf 'Default copy mode: %s\n' "$copy_mode"

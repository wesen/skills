#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_polish_release [mode=quick|release] [output=/path/to/report.json]
EOF
}

mode="release"
output_path=""

for arg in "$@"; do
  case "$arg" in
    mode=*)
      mode="${arg#mode=}"
      ;;
    output=*)
      output_path="${arg#output=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ghidra_re_die "unsupported argument: $arg"
      ;;
  esac
done

case "$mode" in
  quick|release) ;;
  *) ghidra_re_die "unsupported mode: $mode" ;;
esac

ghidra_re_ensure_workspace
report_dir="$GHIDRA_LOGS_DIR/polish"
mkdir -p "$report_dir"
if [[ -z "$output_path" ]]; then
  output_path="$report_dir/polish-$(ghidra_re_timestamp)-$mode.json"
fi

results_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-polish-results.XXXXXX")"
tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/ghidra-polish.XXXXXX")"

cleanup() {
  rm -f "$results_file"
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

record_check() {
  local name="$1"
  shift
  local log_file="$tmp_dir/$(ghidra_re_sanitize_name "$name").log"
  local status="passed"
  if "$@" >"$log_file" 2>&1; then
    :
  else
    status="failed"
  fi
  python3 - "$results_file" "$name" "$status" "$log_file" <<'PY'
import json, pathlib, sys
results_path = pathlib.Path(sys.argv[1])
payload = {
    "name": sys.argv[2],
    "status": sys.argv[3],
    "log": pathlib.Path(sys.argv[4]).read_text(encoding="utf-8", errors="replace"),
}
with results_path.open("a", encoding="utf-8") as handle:
    handle.write(json.dumps(payload) + "\n")
PY
}

record_check "bash-syntax" bash -lc '
  set -euo pipefail
  for file in "$1"/scripts/* "$1"/scripts/common.sh; do
    [[ -f "$file" ]] || continue
    if head -n 1 "$file" | grep -q "bash"; then
      bash -n "$file"
    fi
  done
' bash "$GHIDRA_RE_ROOT"

record_check "python-compile" python3 -m py_compile "$GHIDRA_RE_ROOT/scripts/ghidra_mission_backend.py"
record_check "doctor" "$GHIDRA_RE_ROOT/scripts/doctor"
record_check "bridge-build" "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_build"
record_check "share-package" "$GHIDRA_RE_ROOT/scripts/build_share_package" "$tmp_dir/share.zip"
record_check "windows-share-package" "$GHIDRA_RE_ROOT/scripts/build_windows_desktop_share_package" "$tmp_dir/windows-share.zip"

if [[ "$mode" == "release" ]]; then
  record_check "mac-share-package" "$GHIDRA_RE_ROOT/scripts/build_mac_desktop_share_package" "$tmp_dir/mac-share.zip" --without-ghidra-payload
  record_check "bridge-session-registry" "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_sessions"
fi

python3 - "$results_file" "$output_path" "$mode" <<'PY'
import datetime as dt
import json
import pathlib
import sys

results = []
for line in pathlib.Path(sys.argv[1]).read_text(encoding="utf-8").splitlines():
    if line.strip():
        results.append(json.loads(line))

failed = [item for item in results if item["status"] != "passed"]
payload = {
    "generated_at": dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "mode": sys.argv[3],
    "ok": not failed,
    "checks": results,
    "failed_checks": [item["name"] for item in failed],
}
path = pathlib.Path(sys.argv[2])
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
print(json.dumps(payload, indent=2))
PY

printf 'Polish report: %s\n' "$output_path"

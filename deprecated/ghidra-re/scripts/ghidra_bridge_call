#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_call <endpoint> [json_body|@json_file|-]
EOF
}

[[ $# -ge 1 && $# -le 2 ]] || {
  usage >&2
  exit 1
}

endpoint="$1"
if [[ $# -ge 2 ]]; then
  body_arg="$2"
else
  body_arg='{}'
fi
body=""
url=""
token=""
session_file=""
selector_values=""
requested_session=""
requested_project=""
requested_program=""

[[ "$endpoint" == /* ]] || endpoint="/$endpoint"

case "$body_arg" in
  @*)
    [[ -f "${body_arg#@}" ]] || ghidra_re_die "JSON body file not found: ${body_arg#@}"
    body="$(cat "${body_arg#@}")"
    ;;
  -)
    body="$(cat)"
    ;;
  *)
    body="$body_arg"
    ;;
esac

selector_values="$(ghidra_re_bridge_extract_selectors_from_json "$body")"
IFS=$'\t' read -r requested_session requested_project requested_program <<<"$selector_values"
session_file="$(ghidra_re_bridge_select_session "$requested_session" "$requested_project" "$requested_program")"
ghidra_re_bridge_session_healthy_file "$session_file" || \
  ghidra_re_die "bridge session at $session_file is stale or unreachable; arm or reopen that target"

url="$(ghidra_re_bridge_read_value_from_file "$session_file" bridge_url)"
token="$(ghidra_re_bridge_read_value_from_file "$session_file" token)"
[[ -n "$url" && -n "$token" ]] || ghidra_re_die "bridge session is missing bridge_url or token"

curl -sS \
  -X POST \
  -H "Authorization: Bearer $token" \
  -H 'Content-Type: application/json' \
  --data-binary "$body" \
  "$url$endpoint"

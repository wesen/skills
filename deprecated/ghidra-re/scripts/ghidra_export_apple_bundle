#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_export_apple_bundle <project_name> <program_name>
EOF
}

[[ $# -eq 2 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_ensure_workspace
ghidra_re_require_project "$project_name"

export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
log_file="$log_dir/export-${timestamp}.log"
script_log="$log_dir/export-${timestamp}.script.log"
script_path="$(ghidra_re_script_path)"
analyze_headless="$(ghidra_re_analyze_headless_path)"

mkdir -p "$export_dir" "$log_dir"

optional_args=()
while IFS= read -r -d '' item; do
  optional_args+=("$item")
done < <(ghidra_re_optional_headless_args)

analysis_args=()
case "${GHIDRA_EXPORT_ANALYZE:-0}" in
  1|true|yes|on)
    ;;
  0|false|no|off|"")
    analysis_args=(-noanalysis)
    ;;
  *)
    ghidra_re_die "unsupported GHIDRA_EXPORT_ANALYZE: ${GHIDRA_EXPORT_ANALYZE}"
    ;;
esac

cmd=(
  "$analyze_headless"
  "$(ghidra_re_project_location "$project_name")"
  "$project_name"
  -process "$program_name"
  -scriptPath "$script_path"
)
if [[ ${#analysis_args[@]} -gt 0 ]]; then
  cmd+=("${analysis_args[@]}")
fi
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
if ghidra_re_flag_enabled "${GHIDRA_EXPORT_DEMANGLE:-1}"; then
  cmd+=(-postScript DemangleAllScript.java)
fi
cmd+=(-postScript ExportAppleBundle.java "outdir=${export_dir}")
cmd+=(
  -log "$log_file"
  -scriptlog "$script_log"
)

"${cmd[@]}"

expected_files=(
  "$export_dir/program_summary.json"
  "$export_dir/objc_metadata.json"
  "$export_dir/function_inventory.json"
  "$export_dir/symbols.json"
  "$export_dir/strings.json"
)
for output_path in "${expected_files[@]}"; do
  [[ -f "$output_path" ]] || ghidra_re_die "expected export file is missing: $output_path"
done

printf 'Exported Apple bundle for %s/%s\n' "$project_name" "$program_name"
printf 'Export dir: %s\n' "$export_dir"
printf 'Files:\n'
printf '  %s\n' "$export_dir/program_summary.json"
printf '  %s\n' "$export_dir/objc_metadata.json"
printf '  %s\n' "$export_dir/function_inventory.json"
printf '  %s\n' "$export_dir/symbols.json"
printf '  %s\n' "$export_dir/strings.json"
printf 'Log: %s\n' "$log_file"
printf 'Script log: %s\n' "$script_log"

#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

body="$(ghidra_re_bridge_json_from_kv "$@")"
response="$("$SCRIPT_DIR/ghidra_bridge_call" /session "$body")"
printf '%s' "$response" | "$(ghidra_re_python)" -c 'import json, sys
payload = json.loads(sys.stdin.read())
print(json.dumps(payload["result"]["current_context"], indent=2))'

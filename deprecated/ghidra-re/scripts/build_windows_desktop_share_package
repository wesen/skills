#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: build_windows_desktop_share_package [output_zip] [--ghidra-zip /path/to/ghidra.zip]

Builds a Windows-friendly share archive that can:
  - install the ghidra-re skill into %USERPROFILE%\.codex\skills\ghidra-re
  - install Git for Windows with winget when Git Bash is missing
  - install Java 21 with winget when a usable JDK is missing
  - install Ghidra from an embedded zip payload or a local ghidra_*.zip placed next to the installer

The generated installer is meant to be launched from Windows Explorer via:
  Install Ghidra RE.cmd
EOF
}

output_path=""
ghidra_zip_path=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --ghidra-zip)
      [[ $# -ge 2 ]] || ghidra_re_die "missing value for --ghidra-zip"
      ghidra_zip_path="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -z "$output_path" ]]; then
        output_path="$1"
        shift
      else
        ghidra_re_die "unexpected argument: $1"
      fi
      ;;
  esac
done

if [[ -z "$output_path" ]]; then
  output_path="$PWD/ghidra-re-windows-desktop-share-$(date '+%Y%m%d-%H%M%S').zip"
fi

if [[ -n "$ghidra_zip_path" ]]; then
  [[ -f "$ghidra_zip_path" ]] || ghidra_re_die "ghidra zip not found: $ghidra_zip_path"
fi

stage_root="$(mktemp -d "${TMPDIR:-/tmp}/ghidra-re-win-share.XXXXXX")"
package_root="$stage_root/ghidra-re-windows-desktop-share"
package_skill_dir="$package_root/ghidra-re"
package_payload_dir="$package_root/payload"

cleanup() {
  rm -rf "$stage_root"
}
trap cleanup EXIT

mkdir -p "$package_root" "$package_payload_dir"
rsync -a \
  --exclude '.git' \
  --exclude '.git/' \
  --exclude '.DS_Store' \
  --exclude '__MACOSX' \
  --exclude '.gradle/' \
  --exclude 'build/' \
  "$GHIDRA_RE_ROOT/" \
  "$package_skill_dir/"

embedded_ghidra=false
if [[ -n "$ghidra_zip_path" ]]; then
  cp "$ghidra_zip_path" "$package_payload_dir/Ghidra.zip"
  embedded_ghidra=true
fi

cat >"$package_root/package-info.json" <<EOF
{
  "package_name": "ghidra-re-windows-desktop-share",
  "built_at": "$(date -u '+%Y-%m-%dT%H:%M:%SZ')",
  "skill_name": "ghidra-re",
  "embedded_ghidra_payload": ${embedded_ghidra}
}
EOF

cat >"$package_root/Install Ghidra RE.cmd" <<'EOF'
@echo off
setlocal
powershell -NoProfile -ExecutionPolicy Bypass -File "%~dp0Install Ghidra RE.ps1"
exit /b %ERRORLEVEL%
EOF

cat >"$package_root/Install Ghidra RE.ps1" <<'EOF'
$ErrorActionPreference = "Stop"

function Say($msg) {
  Write-Host $msg
}

$ScriptDir = Split-Path -Parent $MyInvocation.MyCommand.Path
$PackageSkillDir = Join-Path $ScriptDir "ghidra-re"
$PayloadDir = Join-Path $ScriptDir "payload"
$PackageInfoPath = Join-Path $ScriptDir "package-info.json"
$PackageInfo = Get-Content $PackageInfoPath | ConvertFrom-Json

$CodexHome = if ($env:CODEX_HOME) { $env:CODEX_HOME } else { Join-Path $env:USERPROFILE ".codex" }
$InstallBase = Join-Path $CodexHome "skills"
$TargetDir = Join-Path $InstallBase "ghidra-re"
$Timestamp = Get-Date -Format "yyyyMMdd-HHmmss"
$DefaultGhidraTarget = Join-Path $env:LOCALAPPDATA "Programs\Ghidra"
$ConfigDir = if ($env:XDG_CONFIG_HOME) { Join-Path $env:XDG_CONFIG_HOME "ghidra-re" } else { Join-Path $env:USERPROFILE ".config\ghidra-re" }

function Find-Bash {
  $candidates = @(
    (Get-Command bash.exe -ErrorAction SilentlyContinue | ForEach-Object { $_.Source }),
    "C:\Program Files\Git\bin\bash.exe",
    "C:\Program Files\Git\usr\bin\bash.exe"
  ) | Where-Object { $_ -and (Test-Path $_) }
  return ($candidates | Select-Object -First 1)
}

function Find-Cygpath($BashPath) {
  if (-not $BashPath) { return $null }
  $gitRoot = Split-Path (Split-Path $BashPath -Parent) -Parent
  $candidate = Join-Path $gitRoot "usr\bin\cygpath.exe"
  if (Test-Path $candidate) { return $candidate }
  return $null
}

function To-BashPath($Path, $CygpathPath) {
  if ($CygpathPath -and (Test-Path $CygpathPath)) {
    return (& $CygpathPath -u $Path).Trim()
  }
  return ($Path -replace '\\','/')
}

function Ensure-GitBash {
  $bash = Find-Bash
  if ($bash) { return $bash }
  if (Get-Command winget.exe -ErrorAction SilentlyContinue) {
    Say "Installing Git for Windows with winget"
    winget install -e --id Git.Git --accept-package-agreements --accept-source-agreements | Out-Null
    $bash = Find-Bash
    if ($bash) { return $bash }
  }
  throw "Git Bash was not found and could not be installed automatically."
}

function Find-Jdk21 {
  $candidates = @(
    $env:JAVA_HOME,
    "C:\Program Files\Eclipse Adoptium\jdk-21",
    "C:\Program Files\Java\jdk-21"
  ) + (Get-ChildItem "C:\Program Files\Eclipse Adoptium" -Filter "jdk-21*" -ErrorAction SilentlyContinue | ForEach-Object { $_.FullName }) + `
      (Get-ChildItem "C:\Program Files\Java" -Filter "jdk-21*" -ErrorAction SilentlyContinue | ForEach-Object { $_.FullName })
  foreach ($candidate in $candidates) {
    if ($candidate -and (Test-Path (Join-Path $candidate "bin\java.exe"))) {
      return $candidate
    }
  }
  return $null
}

function Ensure-Jdk21 {
  $jdk = Find-Jdk21
  if ($jdk) { return $jdk }
  if (Get-Command winget.exe -ErrorAction SilentlyContinue) {
    Say "Installing Java 21 with winget"
    winget install -e --id EclipseAdoptium.Temurin.21.JDK --accept-package-agreements --accept-source-agreements | Out-Null
    $jdk = Find-Jdk21
    if ($jdk) { return $jdk }
  }
  throw "Java 21 was not found and could not be installed automatically."
}

function Find-Ghidra {
  $candidates = @(
    $env:GHIDRA_INSTALL_DIR,
    "C:\Program Files\Ghidra",
    "C:\Tools\Ghidra",
    $DefaultGhidraTarget
  ) + (Get-ChildItem "C:\Program Files" -Filter "ghidra_*" -Directory -ErrorAction SilentlyContinue | ForEach-Object { $_.FullName }) + `
      (Get-ChildItem "$env:USERPROFILE\Downloads" -Filter "ghidra_*" -Directory -ErrorAction SilentlyContinue | ForEach-Object { $_.FullName })
  foreach ($candidate in $candidates) {
    if ($candidate -and (Test-Path (Join-Path $candidate "support\analyzeHeadless.bat")) -and (Test-Path (Join-Path $candidate "ghidraRun.bat"))) {
      return $candidate
    }
  }
  return $null
}

function Expand-GhidraZip($ZipPath, $TargetDir) {
  $tmp = Join-Path $env:TEMP ("ghidra-re-win-install-" + [guid]::NewGuid().ToString())
  New-Item -ItemType Directory -Force -Path $tmp | Out-Null
  Expand-Archive -LiteralPath $ZipPath -DestinationPath $tmp -Force
  $extracted = Get-ChildItem $tmp | Select-Object -First 1
  if (-not $extracted) {
    throw "Expanded Ghidra zip did not contain a top-level directory."
  }
  if (Test-Path $TargetDir) {
    $backup = "$TargetDir.backup-$Timestamp"
    Move-Item $TargetDir $backup -Force
    Say "Backed up existing Ghidra to $backup"
  }
  New-Item -ItemType Directory -Force -Path (Split-Path $TargetDir -Parent) | Out-Null
  Move-Item $extracted.FullName $TargetDir -Force
  Remove-Item $tmp -Recurse -Force
}

function Ensure-Ghidra {
  $ghidra = Find-Ghidra
  if ($ghidra) { return $ghidra }

  $embeddedZip = Join-Path $PayloadDir "Ghidra.zip"
  if (Test-Path $embeddedZip) {
    Say "Installing embedded Ghidra payload"
    Expand-GhidraZip $embeddedZip $DefaultGhidraTarget
    $ghidra = Find-Ghidra
    if ($ghidra) { return $ghidra }
  }

  $localZip = Get-ChildItem $ScriptDir -Filter "ghidra_*.zip" -ErrorAction SilentlyContinue | Select-Object -First 1
  if ($localZip) {
    Say "Installing Ghidra from $($localZip.FullName)"
    Expand-GhidraZip $localZip.FullName $DefaultGhidraTarget
    $ghidra = Find-Ghidra
    if ($ghidra) { return $ghidra }
  }

  throw "Ghidra was not found. Place a ghidra_*.zip next to the installer or set GHIDRA_INSTALL_DIR before rerunning."
}

function Install-GhidraRePowerShellModule {
  $moduleRoots = @(
    (Join-Path $env:USERPROFILE "Documents\PowerShell\Modules"),
    (Join-Path $env:USERPROFILE "Documents\WindowsPowerShell\Modules")
  ) | Select-Object -Unique

  foreach ($root in $moduleRoots) {
    New-Item -ItemType Directory -Force -Path $root | Out-Null
    $destination = Join-Path $root "GhidraRe"
    if (Test-Path $destination) {
      Remove-Item $destination -Recurse -Force
    }
    New-Item -ItemType Directory -Force -Path $destination | Out-Null
    Copy-Item (Join-Path $TargetDir "powershell\*") $destination -Recurse -Force
  }
}

New-Item -ItemType Directory -Force -Path $InstallBase | Out-Null
if (Test-Path $TargetDir) {
  $backup = "$TargetDir.backup-$Timestamp"
  Move-Item $TargetDir $backup -Force
  Say "Backed up existing skill to $backup"
}
Copy-Item $PackageSkillDir $TargetDir -Recurse -Force

$bashPath = Ensure-GitBash
$cygpathPath = Find-Cygpath $bashPath
$jdkDir = Ensure-Jdk21
$ghidraDir = Ensure-Ghidra

$env:GHIDRA_INSTALL_DIR = $ghidraDir
$env:GHIDRA_JDK = $jdkDir

Install-GhidraRePowerShellModule

$bootstrapPath = Join-Path $TargetDir "scripts\bootstrap"
$bootstrapBashPath = To-BashPath $bootstrapPath $cygpathPath

Say "Running bootstrap from Git Bash"
& $bashPath -lc "export GHIDRA_INSTALL_DIR='$(To-BashPath $ghidraDir $cygpathPath)'; export GHIDRA_JDK='$(To-BashPath $jdkDir $cygpathPath)'; '$bootstrapBashPath'"

Say "Installed ghidra-re to $TargetDir"
Say "Ghidra: $ghidraDir"
Say "JDK: $jdkDir"
Say "PowerShell module: GhidraRe"
Say "Config: $(Join-Path $ConfigDir 'config.env')"
Say "To start from PowerShell:"
Say "  Import-Module GhidraRe"
Say "  Get-GhidraReBridgeSessions"
Say "If your Apple binaries live in a mounted macOS image, add it after install:"
Say "  ghidra_source_add mac-image root=/d/macos-root platform=macos-image copy=cache"
EOF

cat >"$package_root/README.txt" <<'EOF'
ghidra-re Windows desktop share package

1. Unzip this archive on the Windows machine.
2. Double-click "Install Ghidra RE.cmd".
3. The installer will:
   - copy the skill into %USERPROFILE%\.codex\skills\ghidra-re
   - install the GhidraRe PowerShell module into your user module paths
   - install Git for Windows with winget if Git Bash is missing
   - install Java 21 with winget if a usable JDK is missing
   - reuse an existing Ghidra install, install an embedded Ghidra zip if present,
     or install a local ghidra_*.zip placed next to the installer
   - run scripts/bootstrap through Git Bash

Notes:
- You can use either Git Bash or PowerShell after install.
- In PowerShell, start with:
    Import-Module GhidraRe
    Get-GhidraReBridgeSessions
- If you want to analyze Apple targets from Windows, mount or extract a macOS root
  and then register it with:
    ghidra_source_add mac-image root=/d/macos-root platform=macos-image copy=cache
- The source registry lives at:
    %USERPROFILE%\.config\ghidra-re\sources.json
EOF

chmod +x "$package_skill_dir"/scripts/* "$package_root/Install Ghidra RE.cmd"

mkdir -p "$(dirname "$output_path")"
rm -f "$output_path"
(
  cd "$stage_root"
  zip -qr "$output_path" "ghidra-re-windows-desktop-share"
)

printf 'Built windows desktop share package: %s\n' "$output_path"

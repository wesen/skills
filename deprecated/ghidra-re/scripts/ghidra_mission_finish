#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_mission_finish <mission_name> [all=true] [keep_sessions_open=true] [summary=...]
EOF
}

[[ $# -ge 1 ]] || {
  usage >&2
  exit 1
}

mission_name="$1"
shift

all_flag=false
keep_sessions_open=false
summary=""

for arg in "$@"; do
  case "$arg" in
    all=*)
      case "${arg#all=}" in
        true|1|yes|on) all_flag=true ;;
        false|0|no|off) all_flag=false ;;
        *) ghidra_re_die "unsupported all= value: ${arg#all=}" ;;
      esac
      ;;
    keep_sessions_open=*)
      case "${arg#keep_sessions_open=}" in
        true|1|yes|on) keep_sessions_open=true ;;
        false|0|no|off) keep_sessions_open=false ;;
        *) ghidra_re_die "unsupported keep_sessions_open= value: ${arg#keep_sessions_open=}" ;;
      esac
      ;;
    summary=*)
      summary="${arg#summary=}"
      ;;
    note=*)
      summary="${arg#note=}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ghidra_re_die "unsupported argument: $arg"
      ;;
  esac
done

mission_dir="$(ghidra_re_investigation_dir "$mission_name")"
[[ -d "$mission_dir" ]] || ghidra_re_die "mission not found: $mission_name"

report_path="$("$SCRIPT_DIR/ghidra_mission_report" "$mission_name" format=path)"
close_summary_file="$(mktemp "${TMPDIR:-/tmp}/ghidra-mission-close.XXXXXX")"

cleanup() {
  rm -f "$close_summary_file"
}
trap cleanup EXIT

if [[ "$keep_sessions_open" == true ]]; then
  printf '{"ok": true, "closed_sessions": [], "failed_sessions": [], "closed_count": 0, "failed_count": 0, "kept_open": true}\n' >"$close_summary_file"
else
  if [[ "$all_flag" == true ]]; then
    "$SCRIPT_DIR/ghidra_bridge_close_all" all=true >"$close_summary_file"
  else
    "$SCRIPT_DIR/ghidra_bridge_close_all" "mission=$mission_name" >"$close_summary_file"
  fi
fi

if [[ -z "$summary" ]]; then
  summary="$(python3 - "$close_summary_file" "$mission_name" "$keep_sessions_open" <<'PY'
import json, pathlib, sys
payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
mission_name = sys.argv[2]
keep_open = sys.argv[3].lower() == "true"
if keep_open:
    print(f"{mission_name} finished; live Ghidra sessions were left open.")
else:
    print(
        f"{mission_name} finished; closed {payload.get('closed_count', 0)} live Ghidra session(s)"
        f" with {payload.get('failed_count', 0)} failure(s)."
    )
PY
)"
fi

metadata_json="$(python3 - "$close_summary_file" "$all_flag" "$keep_sessions_open" <<'PY'
import json, pathlib, sys
payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
payload["all"] = sys.argv[2].lower() == "true"
payload["keep_sessions_open"] = sys.argv[3].lower() == "true"
print(json.dumps(payload))
PY
)"

status="success"
failed_count="$(python3 - "$close_summary_file" <<'PY'
import json, pathlib, sys
payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
print(payload.get("failed_count", 0))
PY
)"
if [[ "$failed_count" != "0" ]]; then
  status="partial"
fi

python3 "$(ghidra_re_mission_backend)" finish \
  --mission-dir "$mission_dir" \
  --status "$status" \
  --summary "$summary" \
  --report-path "$report_path" \
  --metadata-json "$metadata_json" >/dev/null

printf 'Mission finished: %s\n' "$mission_name"
printf 'Report: %s\n' "$report_path"
if [[ "$keep_sessions_open" == true ]]; then
  printf 'Live sessions kept open\n'
else
  printf 'Closed live sessions: %s\n' "$(python3 - "$close_summary_file" <<'PY'
import json, pathlib, sys
payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
print(payload.get("closed_count", 0))
PY
)"
fi

